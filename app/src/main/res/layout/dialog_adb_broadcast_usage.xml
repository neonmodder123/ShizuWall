<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="16dp"
    android:paddingBottom="-16dp">

    <androidx.core.widget.NestedScrollView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="24dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_field_action"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvBroadcastActionValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyBroadcastAction"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_field_component"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvBroadcastComponentValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyBroadcastComponent"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_field_extras"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvBroadcastExtrasValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/adb_broadcast_examples_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_example_enable_selected"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCmdEnableSelected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyCmdEnableSelected"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_example_disable_selected"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCmdDisableSelected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyCmdDisableSelected"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_example_enable_csv"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCmdEnableCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyCmdEnableCsv"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_example_disable_csv"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvCmdDisableCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyCmdDisableCsv"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/adb_broadcast_developer_section_title"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="14sp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_dev_enable_framework"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDevCmdEnableFramework"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:text="cmd connectivity set-chain3-enabled true"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyDevCmdEnableFramework"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_dev_block_package"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDevCmdBlockPackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:text="cmd connectivity set-package-networking-enabled false &lt;package.name&gt;"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyDevCmdBlockPackage"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_dev_unblock_package"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDevCmdUnblockPackage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:text="cmd connectivity set-package-networking-enabled true &lt;package.name&gt;"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyDevCmdUnblockPackage"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_broadcast_dev_disable_framework"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvDevCmdDisableFramework"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginEnd="40dp"
                    android:fontFamily="monospace"
                    android:text="cmd connectivity set-chain3-enabled false"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textIsSelectable="true"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnCopyDevCmdDisableFramework"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|bottom"
                    android:layout_marginTop="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/copy"
                    android:padding="2dp"
                    android:src="@drawable/content_copy_24px"
                    app:tint="?android:attr/textColorSecondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
